{
  "cli": {
    "version": ">= 16.26.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "simulator": {
      "developmentClient": true,
      "ios": {
        "simulator": true
      },
      "distribution": "internal",
      "channel": "simulator"
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "channel": "preview"
    },
    "e2e-android": {
      "distribution": "internal",
      "channel": "e2e",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_E2E": "1",
        "EXPO_PUBLIC_NR_BRIDGE_BASE_URL": "http://10.0.2.2:8000",
        "EXPO_PUBLIC_NOSTR_RELAYS": "ws://10.0.2.2:7777"
      }
    },
    "e2e-ios-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "e2e",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_E2E": "1",
        "EXPO_PUBLIC_NR_BRIDGE_BASE_URL": "http://127.0.0.1:8000",
        "EXPO_PUBLIC_NOSTR_RELAYS": "ws://127.0.0.1:7777"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "preview"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6755037304"
      }
    }
  }
}
