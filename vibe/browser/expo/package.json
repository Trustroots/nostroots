{
  "name": "nr-browser",
  "main": "expo-router/entry",
  "version": "0.0.1",
  "scripts": {
    "write-build-time": "node scripts/write-build-time.js",
    "start": "node scripts/write-build-time.js && expo start",
    "ios": "node scripts/write-build-time.js && expo run:ios",
    "ios:device": "node scripts/run-ios-device.js",
    "android": "expo run:android",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "lint": "eslint ."
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "./jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|react-native-webview|@noble|nostr-tools|nip06)"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "~54.0.21",
    "expo-clipboard": "~8.0.7",
    "expo-constants": "~18.0.10",
    "expo-font": "~14.0.9",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.14",
    "expo-secure-store": "^15.0.7",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-web-browser": "~15.0.8",
    "fast-text-encoding": "^1.0.6",
    "nip06": "^1.2.0",
    "nostr-tools": "2.10.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-get-random-values": "^1.11.0",
    "react-native-safe-area-context": "5.6.1",
    "react-native-screens": "4.16.0",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.15.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@testing-library/react-native": "^13.1.0",
    "@types/jest": "^29.5.12",
    "@types/node": "20.19.24",
    "@types/react": "~19.1.17",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^10.0.0",
    "jest": "^29.2.1",
    "jest-expo": "~54.0.13",
    "typescript": "~5.9.3"
  },
  "private": true,
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
