{
  "name": "nr-app",
  "main": "src/index.ts",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:e2e:metro": "EXPO_PUBLIC_E2E=1 EXPO_PUBLIC_NR_BRIDGE_BASE_URL=http://10.0.2.2:8000 EXPO_PUBLIC_NOSTR_RELAYS=ws://10.0.2.2:7777 EXPO_DEBUG=1 expo start --dev-client --clear",
    "android:e2e:prebuild": "EXPO_PUBLIC_E2E=1 EXPO_PUBLIC_NR_BRIDGE_BASE_URL=http://10.0.2.2:8000 EXPO_PUBLIC_NOSTR_RELAYS=ws://10.0.2.2:7777 expo prebuild --platform android --clean --no-install",
    "android:e2e:install": "bash ./scripts/android-e2e-install.sh",
    "android:e2e:emulator:reset": "sh ./scripts/android-e2e-emulator-reset.sh",
    "android:e2e:adb:host": "sh ./scripts/android-e2e-host-adb.sh",
    "android:e2e:adb:check": "adb devices -l && adb shell pm path org.trustroots.nostroots",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "pnpm run test:unit && pnpm run test:rntl",
    "test:unit": "jest --testMatch \"**/?(*.)+(test|spec).ts\"",
    "test:rntl": "jest --testMatch \"**/?(*.)+(test|spec).tsx\"",
    "test:maestro": "maestro ${MAESTRO_HOST:+--host $MAESTRO_HOST} test .maestro",
    "test:maestro:local": "sh ./scripts/android-e2e-maestro-local.sh",
    "test:ci": "jest --ci --coverage --runInBand",
    "test:coverage": "jest --watchman=false --coverage",
    "test:watch": "jest --watchAll",
    "lint": "eslint .",
    "prepare": "cd .. && husky nr-app/.husky",
    "build:android-e2e-local": "bash ./scripts/android-e2e-build.sh",
    "build:android-development": "eas build --platform android --profile development --non-interactive",
    "build:ios-development": "eas build --platform ios --profile development --non-interactive",
    "build:ios-simulator": "eas build --platform ios --profile simulator --non-interactive",
    "build:android-preview": "eas build --platform android --profile preview --non-interactive",
    "build:android-production": "eas build --platform android --profile production --non-interactive --auto-submit",
    "build:android-e2e": "eas build --platform android --profile e2e-android --non-interactive",
    "build:ios-e2e-simulator": "eas build --platform ios --profile e2e-ios-simulator --non-interactive",
    "build:ios-production": "eas build --platform ios --profile production --non-interactive --auto-submit"
  },
  "pkgx": "facebook.com/watchman",
  "dependencies": {
    "@expo/dom-webview": "^56.0.5",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@mobily/ts-belt": "^3.13.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/native": "^7.2.5",
    "@reduxjs/toolkit": "^2.12.0",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/select": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/tabs": "^1.4.0",
    "@sentry/react-native": "~7.11.0",
    "@trustroots/nr-common": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~56.0.8",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-crypto": "56.0.3",
    "expo-dev-client": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-linking": "~56.0.13",
    "expo-location": "^56.0.15",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-secure-store": "^56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.17",
    "expo-web-browser": "~56.0.5",
    "fast-text-encoding": "^1.0.6",
    "lucide-react-native": "^1.17.0",
    "metro": "^0.84.4",
    "metro-core": "^0.84.4",
    "nativewind": "^4.2.4",
    "nip06": "^1.2.0",
    "nostr-tools": "2.23.5",
    "open-location-code-typescript": "^1.5.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-get-random-values": "^1.11.0",
    "react-native-keyboard-controller": "^1.21.6",
    "react-native-logs": "^5.6.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "~4.3.1",
    "react-native-root-toast": "^4.0.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "^0.8.3",
    "react-redux": "^9.3.0",
    "reactotron-react-native": "^5.2.0",
    "redux-devtools-expo-dev-plugin": "^2.0.0",
    "redux-persist": "^6.0.0",
    "redux-saga": "^1.5.0",
    "redux-saga-promise-actions": "^1.3.5",
    "reselect": "^5.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "ts-pattern": "^5.9.0",
    "url-join-ts": "^1.0.5",
    "utils": "link:@noble/hashes/utils",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@react-native/assets-registry": "^0.85.3",
    "@testing-library/react-native": "^13.1.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.16",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-root-import": "^6.6.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.5",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.4",
    "lint-staged": "^17.0.7",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "private": true,
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-maps",
          "redux-persist"
        ]
      }
    }
  }
}
