{
  "name": "Nostroots Metro",
  "build": {
    "context": "..",
    "dockerfile": "../Dockerfile.app"
  },
  "workspaceFolder": "/app",
  "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind,consistency=cached",
  "runArgs": ["--add-host=host.docker.internal:host-gateway"],
  "forwardPorts": [8081],
  "portsAttributes": {
    "8081": {
      "label": "Metro Bundler",
      "onAutoForward": "notify"
    }
  },
  "containerEnv": {
    "ADB_SERVER_SOCKET": "tcp:host.docker.internal:5037",
    "MAESTRO_HOST": "host.docker.internal",
    "EXPO_USE_METRO_WORKSPACE_ROOT": "1",
    "EXPO_NO_DOTENV": "1"
  },
  "postCreateCommand": "corepack enable && corepack prepare pnpm@9.14.2 --activate && pnpm install --frozen-lockfile",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "remoteUser": "root"
}
